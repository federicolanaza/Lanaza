
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the VirtuLib application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's institutional email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The full name of the user."
        },
        "role": {
          "type": "string",
          "description": "The assigned role of the user ('admin', 'visitor')."
        },
        "isBlocked": {
          "type": "boolean",
          "description": "Indicates whether the user's access has been blocked."
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "role",
        "isBlocked"
      ]
    },
    "ActiveSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActiveSession",
      "type": "object",
      "description": "Tracks a currently active user session in the application.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID or identifier of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address associated with the session."
        },
        "userName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "loginTime": {
          "type": "string",
          "format": "date-time",
          "description": "When the session started."
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time",
          "description": "Last activity timestamp."
        }
      },
      "required": [
        "userId",
        "email",
        "userName",
        "loginTime",
        "lastSeen"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "description": "Records individual library check-in events."
        }
      },
      {
        "path": "/active_sessions/{sessionId}",
        "definition": {
          "entityName": "ActiveSession",
          "schema": {
            "$ref": "#/backend/entities/ActiveSession"
          },
          "description": "Tracks real-time active users. Document ID is typically the user's ID or email hash."
        }
      },
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "User",
          "description": "Dedicated collection for admin role verification."
        }
      }
    ]
  }
}
