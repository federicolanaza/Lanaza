{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "visitor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles and account settings."
        }
      },
      {
        "path": "/admins/{userId}",
        "definition": {
          "schema": { "type": "object", "properties": { "uid": { "type": "string" }, "email": { "type": "string" }, "role": { "type": "string" } } },
          "description": "Verified administrator identifiers."
        }
      },
      {
        "path": "/active_sessions/{sessionId}",
        "definition": {
          "schema": { "type": "object", "properties": { "userId": { "type": "string" }, "email": { "type": "string" }, "userName": { "type": "string" }, "role": { "type": "string" }, "loginTime": { "type": "string" }, "lastSeen": { "type": "string" } } },
          "description": "Real-time user session tracking."
        }
      }
    ]
  }
}