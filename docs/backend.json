{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "visitor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "LibraryLog": {
      "title": "Library Log",
      "type": "object",
      "description": "Record of a library visitor check-in.",
      "properties": {
        "idNumber": { "type": "string" },
        "department": { "type": "string" },
        "studyDuration": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "DeanLog": {
      "title": "Dean Log",
      "type": "object",
      "description": "Record of a dean's office visitor check-in.",
      "properties": {
        "visitorName": { "type": "string" },
        "studentId": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and account settings."
    },
    "/admins/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string" },
          "enrolledAt": { "type": "string" }
        }
      },
      "description": "Verified administrator identifiers for system access."
    },
    "/active_sessions/{sessionId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "email": { "type": "string" },
          "userName": { "type": "string" },
          "role": { "type": "string" },
          "loginTime": { "type": "string" },
          "lastSeen": { "type": "string" }
        }
      },
      "description": "Real-time user session tracking for the admin dashboard."
    },
    "/library_logs/{logId}": {
      "schema": "LibraryLog",
      "description": "Historical library check-in records."
    },
    "/dean_logs/{logId}": {
      "schema": "DeanLog",
      "description": "Historical dean's office queue records."
    }
  }
}