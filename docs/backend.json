
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "visitor"] }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "LibraryLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LibraryLog",
      "type": "object",
      "description": "Records a library check-in event.",
      "properties": {
        "idNumber": { "type": "string" },
        "department": { "type": "string" },
        "studyDuration": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["idNumber", "department", "studyDuration", "timestamp"]
    },
    "DeanLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DeanLog",
      "type": "object",
      "description": "Records a Dean's Office check-in event.",
      "properties": {
        "visitorName": { "type": "string" },
        "studentId": { "type": "string" },
        "purpose": { "type": "string", "enum": ["Signature", "Consultation", "Document Submission"] },
        "status": { "type": "string", "default": "Waiting" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["visitorName", "studentId", "purpose", "status", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/library_logs/{logId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/LibraryLog" },
          "description": "Library check-in logs."
        }
      },
      {
        "path": "/dean_logs/{logId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/DeanLog" },
          "description": "Dean's Office check-in logs."
        }
      }
    ]
  }
}
