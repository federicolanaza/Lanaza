
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isInstitutionalEmail(email) {
      return email.matches('.*@neu\\.edu\\.ph$');
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() 
                   && request.auth.uid == userId 
                   && isInstitutionalEmail(request.resource.data.email);
    }

    // Admin role verification
    match /admins/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Real-time session tracking
    match /active_sessions/{sessionId} {
      allow read: if true;
      allow write, delete: if true;
    }

    // Library check-in logs
    match /library_logs/{logId} {
      allow create: if true;
      allow read, delete: if isSignedIn(); 
    }

    // Dean's Office check-in logs
    match /dean_logs/{logId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }
  }
}
