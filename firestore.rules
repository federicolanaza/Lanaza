
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalEmail() {
      // Use .lower() as CEL (Common Expression Language) does not support .toLocaleLowerCase()
      // Added a null check for robustness
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().endsWith('@neu.edu.ph');
    }

    function isDataInstitutional() {
      // Validates the email domain directly from the request data
      return request.resource.data.email != null && 
             request.resource.data.email.lower().endsWith('@neu.edu.ph');
    }
    
    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId && (isInstitutionalEmail() || isDataInstitutional());
    }

    // Admin role verification
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId && (isInstitutionalEmail() || isDataInstitutional());
    }

    // Real-time session tracking
    match /active_sessions/{sessionId} {
      allow read: if true;
      allow write, delete: if true;
    }

    // Visitor Logs (Library)
    match /library_logs/{logId} {
      allow create: if true;
      allow read: if isSignedIn();
    }

    // Visitor Logs (Dean's Office)
    match /dean_logs/{logId} {
      allow create: if true;
      allow read: if isSignedIn();
    }
  }
}
